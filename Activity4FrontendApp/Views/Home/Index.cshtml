@{
    ViewData["Title"] = "Home";
}

<section class="editorial-hero">
    <div class="hero-text-block">
        <h1>PORTFOLIO</h1>
        <div class="hero-name">
            <span>CYRIS</span>
            <span>URBANO</span>
        </div>
        <p>Frontend Designer • Student Developer • Creative Portfolio</p>
    </div>

    <div class="hero-image-block">
        <img src="~/images/main.png" alt="Portfolio Image">
        </div>
    </section>

    <section class="editorial-grid">
        <div class="editorial-card about-card">
            <h2>ABOUT ME</h2>
            <div class="image-box">
                <img src="~/images/me.png" alt="About Image">
                </div>
                <p>
                    <p>
                        I am a student who loves trying new things and exploring fresh ideas.
                        I enjoy being creative, learning along the way, and building designs that reflect my personality.
                        I also have a soft spot for Milo and chocolate, which always make my day better.
                    </p>
                </p>
            </div>

            <div class="editorial-card create-card">
                <h2>I CREATE</h2>
                <div class="skills-grid">
                    <span>UI Design</span>
                    <span>Web Layouts</span>
                    <span>Portfolio Pages</span>
                    <span>Frontend Code</span>
                    <span>Responsive Design</span>
                    <span>Creative Concepts</span>
                </div>
            </div>

            <div class="editorial-card case-card">
                <h2>THE CASE</h2>
                <div class="mini-gallery">
                    <img src="~/images/1.png" alt="Case image 1">
                        <img src="~/images/2.png" alt="Case image 2">
                            <img src="~/images/3.png" alt="Case image 3">
                                <img src="~/images/4.png" alt="Case image 4">
                                </div>
                            </div>

                            <div class="editorial-card stories-card">
                                <h2>STORIES</h2>
                                <div class="stories-grid">
                                    <div class="story-box">Brand Visual</div>
                                    <div class="story-box">Portfolio Theme</div>
                                    <div class="story-box">Creative Layout</div>
                                </div>
                            </div>

                            <div class="editorial-card highlights-card">
                                <h2>HIGHLIGHTS</h2>
                                <div class="circle-row">
                                    <div class="circle-item">HTML</div>
                                    <div class="circle-item">CSS</div>
                                    <div class="circle-item">MVC</div>
                                    <div class="circle-item">UI</div>
                                    <div class="circle-item">Design</div>
                                    <div class="circle-item">Code</div>
                                </div>
                            </div>

                            <div class="editorial-card education-card">
                                <h2>EDUCATION</h2>
                                <div class="edu-box">
                                    <h3>BSIT Student</h3>
                                    <p>Applications Development and Emerging Technologies</p>
                                </div>
                                <div class="edu-box">
                                    <h3>Frontend Focus</h3>
                                    <p>Learning ASP.NET MVC, web layout, and interface design</p>
                                </div>
                            </div>
                        </section>
